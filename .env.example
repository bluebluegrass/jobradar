# Frontend base URL (where Vite runs)
APP_BASE_URL=http://localhost:5173
# Alias also supported:
# FRONTEND_BASE_URL=http://localhost:5173

# Backend server
# For Render, `PORT` is injected automatically.
PORT=8787
SERVER_PORT=8787
SERVER_HOST=127.0.0.1
SERVER_BASE_URL=http://localhost:8787
SESSION_COOKIE_NAME=jobradar_sid
COOKIE_SECURE=false

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Optional alternative: full JSON from Google OAuth app credentials
# GOOGLE_OAUTH_CREDENTIALS_JSON={"web":{"client_id":"...","client_secret":"..."}}
# Must match Google Cloud Console redirect URI
GOOGLE_REDIRECT_URI=http://localhost:8787/api/auth/google/callback

# Microsoft OAuth
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
MICROSOFT_TENANT_ID=common
# Must match Azure App Registration redirect URI
MICROSOFT_REDIRECT_URI=http://localhost:8787/api/auth/outlook/callback
# Aliases also supported:
# MS_CLIENT_ID=your_microsoft_client_id
# MS_CLIENT_SECRET=your_microsoft_client_secret
# MS_TENANT_ID=common
# MS_REDIRECT_URI=http://localhost:8787/api/auth/outlook/callback
